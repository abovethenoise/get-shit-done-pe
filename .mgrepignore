# =============================================================================
# .mgrepignore — Exclude from semantic search indexing
# =============================================================================
# Goal: Don't spend tokens indexing generated code, binaries, lockfiles,
# vendored deps, or non-source artifacts.

# -----------------------------------------------------------------------------
# Dependencies (vendored / installed)
# -----------------------------------------------------------------------------
node_modules/
get-shit-done/bin/node_modules/

# -----------------------------------------------------------------------------
# Lockfiles (large, no semantic value)
# -----------------------------------------------------------------------------
package-lock.json
yarn.lock
pnpm-lock.yaml

# -----------------------------------------------------------------------------
# Build artifacts
# -----------------------------------------------------------------------------
hooks/dist/

# -----------------------------------------------------------------------------
# Test coverage reports
# -----------------------------------------------------------------------------
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# Git internals
# -----------------------------------------------------------------------------
.git/

# -----------------------------------------------------------------------------
# Planning / research / internal docs (not useful for code search)
# -----------------------------------------------------------------------------
.planning/
.archive/
reports/
analysis/

# -----------------------------------------------------------------------------
# Media / binary files
# -----------------------------------------------------------------------------
animation/
*.gif
*.png
*.jpg
*.jpeg
*.svg
*.ico

# -----------------------------------------------------------------------------
# Logs, temp, OS junk
# -----------------------------------------------------------------------------
*.log
*.tmp
.DS_Store
.cache/
tmp/
temp/

# -----------------------------------------------------------------------------
# IDE config
# -----------------------------------------------------------------------------
.idea/
.vscode/

# -----------------------------------------------------------------------------
# Secrets / env
# -----------------------------------------------------------------------------
.env
.env.*
*.pem
*.key
